{
  "name": "rebookindia",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:customer": "turbo run dev --filter=customer",
    "dev:vendor": "turbo run dev --filter=vendor",
    "dev:admin": "turbo run dev --filter=admin",
    "build": "turbo run build",
    "build:customer": "turbo run build --filter=customer",
    "build:vendor": "turbo run build --filter=vendor",
    "build:admin": "turbo run build --filter=admin",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "seed": "npm run seed --workspace=packages/appwrite"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.3.3",
    "typescript": "^5.4.5"
  },
  "packageManager": "npm@10.5.0",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  }
}
